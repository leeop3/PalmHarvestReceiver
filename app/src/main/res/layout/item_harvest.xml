<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardElevation="2dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">
        <TextView android:id="@+id/txtHarvester" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textStyle="bold" android:textSize="16sp" />
        <TextView android:id="@+id/txtBlock" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <TextView android:id="@+id/txtStats" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#666666" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>